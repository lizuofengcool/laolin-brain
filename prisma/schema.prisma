generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== SaaS 多租户核心模型 ====================

model Tenant {
  id          String   @id @default(cuid())
  name        String   // 租户名称
  plan        String   @default("free") // 套餐：free / pro / enterprise
  status      String   @default("active") // 状态：active / suspended / cancelled
  storageQuota BigInt  @default(5368709120) // 存储配额（字节），默认 5GB
  aiQuota     Int      @default(200) // AI 调用配额（次/天）
  aiUsed      Int      @default(0) // 今日已用 AI 次数
  aiResetDate DateTime? // AI 配额重置日期
  storageUsed BigInt   @default(0) // 已用存储（字节）
  region      String   @default("cn") // 数据区域：cn / us / eu
  storageProvider String @default("local") // 存储提供商：local / aliyun / r2
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  currentPeriodEnd DateTime? // 当前订阅周期结束时间
  trialEndsAt DateTime? // 试用结束时间

  // 关联
  users           TenantUser[]
  files           File[]
  folders         Folder[]
  subscriptions   Subscription[]
  orders          Order[]
  storageConfigs  StorageConfig[]
  faceGroups      FaceGroup[]

  @@index([status])
  @@index([plan])
}

model TenantUser {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      String   @default("owner") // 角色：owner / admin / member
  joinedAt  DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  storageMode String   @default("local")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  tenantMemberships TenantUser[]
  files             File[]
  folders           Folder[]

  // 便捷方法：获取当前激活的租户
  @@map("users")
}

// ==================== 订阅与计费 ====================

model Subscription {
  id          String   @id @default(cuid())
  tenantId    String
  plan        String   // 套餐：free / pro / enterprise
  status      String   @default("active") // active / cancelled / past_due
  price       Decimal  @default(0)
  interval    String   @default("month") // month / year
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean  @default(false)
  canceledAt  DateTime?
  startedAt   DateTime
  endedAt     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@index([tenantId])
  @@index([status])
}

model Order {
  id          String   @id @default(cuid())
  tenantId    String
  subscriptionId String?
  orderNo     String   @unique // 订单号
  amount      Decimal  // 金额（分）
  currency    String   @default("cny")
  status      String   @default("pending") // pending / paid / failed / refunded
  payMethod   String? // 支付方式：alipay / wechat
  payTime     DateTime?
  transactionId String? // 第三方交易号
  plan        String
  interval    String
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([orderNo])
}

// ==================== 存储配置 ====================

model StorageConfig {
  id          String   @id @default(cuid())
  tenantId    String
  provider    String   // aliyun / r2 / local
  config      String   // JSON 格式的配置信息（加密存储）
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@unique([tenantId, provider])
}

// ==================== 业务模型（已升级为多租户） ====================

model File {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  fileName     String
  fileType     String
  fileSize     Int
  filePath     String?
  textContent  String?
  thumbnailUrl String?
  storageMode  String   @default("local")
  folderId     String?
  tags         String   @default("")
  isFavorite   Boolean  @default(false)
  isDeleted    Boolean  @default(false)
  deletedAt    DateTime?
  fileHash     String?
  summary      String?
  keyPoints    String   @default("")
  syncStatus   String   @default("local") // local / synced / pending / conflict
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder       Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  shares       FileShare[]
  versions     FileVersion[]
  faces        FaceInstance[]
  embedding    FileEmbedding?

  @@index([tenantId])
  @@index([tenantId, isDeleted])
  @@index([tenantId, userId])
  @@index([folderId])
  @@index([tenantId, isFavorite])
  @@index([fileHash])
  @@index([createdAt])
  @@index([fileType])
  @@index([syncStatus])
}

model FileVersion {
  id           String   @id @default(cuid())
  fileId       String
  fileName     String
  fileSize     Int
  filePath     String?
  textContent  String?
  thumbnailUrl String?
  version      Int
  createdAt    DateTime @default(now())
  file         File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
}

model Folder {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  files     File[]
  parent    Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[] @relation("FolderTree")

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([parentId])
  @@unique([tenantId, name, parentId])
}

model FileShare {
  id        String   @id @default(cuid())
  fileId    String
  token     String   @unique
  password  String?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([token])
}

model FileEmbedding {
  id        String   @id @default(cuid())
  fileId    String   @unique
  tenantId  String
  userId    String
  embedding String
  createdAt DateTime @default(now())
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([fileId])
}

model FaceGroup {
  id        String        @id @default(cuid())
  tenantId  String
  userId    String
  name      String?
  thumbnail String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  faces     FaceInstance[]

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, userId])
  @@unique([tenantId, name])
}

model FaceInstance {
  id          String    @id @default(cuid())
  groupId     String
  fileId      String
  embedding   String
  description String
  bboxX       Int
  bboxY       Int
  bboxW       Int
  bboxH       Int
  createdAt   DateTime  @default(now())
  group       FaceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  file        File      @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([fileId])
}

// ==================== 同步相关 ====================

model SyncLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  syncType  String   // full / incremental
  status    String   // success / failed / in_progress
  filesSynced Int    @default(0)
  filesTotal Int     @default(0)
  bytesSynced BigInt @default(0)
  errorMessage String?
  startedAt DateTime
  endedAt   DateTime?

  @@index([tenantId])
  @@index([status])
  @@index([startedAt])
}

model SyncQueue {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  operation String   // upload / update / delete
  fileId    String?
  fileName  String?
  fileHash  String?
  filePath  String?
  folderId  String?
  status    String   // pending / processing / failed / completed
  retryCount Int     @default(0)
  maxRetries Int     @default(3)
  errorMessage String?
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  processedAt DateTime?

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@index([tenantId, status])
}

// ==================== 通知和日志模型 ====================

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  type      String   // system, payment, storage, ai, share
  title     String
  content   String?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, userId, isRead])
  @@index([createdAt])
}

model ActivityLog {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  action       String   // create, update, delete, download, share, login, etc.
  resourceType String   // file, folder, user, tenant, setting, etc.
  resourceId   String?
  details      String?  // JSON string
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, action])
  @@index([tenantId, resourceType])
  @@index([createdAt])
}

// ==================== 团队协作模型 ====================

model Invitation {
  id         String   @id @default(cuid())
  tenantId   String
  email      String
  role       String   @default("member") // owner / admin / member / viewer
  status     String   @default("pending") // pending / accepted / revoked / expired
  token      String   @unique
  invitedBy  String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([email])
  @@index([token])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  tenantId  String
  fileId    String
  userId    String
  content   String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, fileId])
  @@index([tenantId, userId])
  @@index([parentId])
  @@index([createdAt])
}

// ==================== 高级功能模型 ====================

model AutomationRule {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  name       String
  trigger    String   // file_uploaded
  conditions String   // JSON string
  actions    String   // JSON string
  enabled    Boolean  @default(true)
  priority   Int      @default(0)
  runCount   Int      @default(0)
  lastRunAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, enabled])
  @@index([createdAt])
}

model AccessHistory {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  fileId     String
  accessType String   // view / download / edit
  accessCount Int     @default(1)
  lastAccessedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, fileId])
  @@index([tenantId, userId, lastAccessedAt])
  @@unique([tenantId, userId, fileId, accessType])
}

model Shortcut {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  fileId     String?
  folderId   String?
  name       String
  icon       String?
  sortOrder  Int      @default(0)
  isPinned   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, userId, isPinned])
  @@index([sortOrder])
}

// ==================== 开放平台和系统运维模型 ====================

model ApiKey {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  name       String
  key        String   @unique
  secret     String
  scopes     String   // JSON string array
  expiresAt  DateTime?
  lastUsedAt DateTime?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, enabled])
  @@index([createdAt])
}

model Webhook {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  name       String
  url        String
  events     String   // JSON string array
  secret     String?
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, enabled])
  @@index([createdAt])
}

model WebhookLog {
  id         String   @id @default(cuid())
  tenantId   String
  webhookId  String
  event      String
  status     Int
  response   String?
  retryCount Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, webhookId])
  @@index([tenantId, event])
  @@index([createdAt])
}

model Backup {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  name       String
  type       String   // full / incremental
  size       Int      @default(0)
  fileCount  Int      @default(0)
  status     String   // pending / running / completed / failed
  error      String?
  filePath   String?
  createdAt  DateTime @default(now())
  completedAt DateTime?

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@index([createdAt])
}

model SystemLog {
  id         String   @id @default(cuid())
  tenantId   String?
  level      String   // info / warn / error / debug
  module     String
  message    String
  details    String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([level])
  @@index([module])
  @@index([createdAt])
}
