# ============================================
# laolin-brain 环境变量配置模板
# ============================================
# 复制此文件为 .env 并修改配置
# ============================================

# ============================================
# 基础配置
# ============================================

# 运行环境: development / production / test
NODE_ENV=development

# 服务端口
PORT=3000

# 应用URL（用于生成链接和回调）
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ============================================
# 数据库配置
# ============================================

# SQLite数据库路径
DATABASE_URL=file:./data/db.sqlite

# ============================================
# 安全配置
# ============================================

# JWT/HMAC签名密钥（生产环境必须修改为随机字符串，至少32字符）
TOKEN_SECRET=change-me-to-a-random-32-char-string-at-least-32-chars
JWT_SECRET=change-me-to-a-random-32-char-string-at-least-32-chars

# 密码加密盐值（可选）
PASSWORD_SALT=change-me-to-a-random-salt

# ============================================
# SaaS 多租户配置
# ============================================

# 是否启用SaaS模式
SAAS_ENABLED=true

# 默认套餐: free / pro / enterprise
DEFAULT_PLAN=free

# 免费试用天数
TRIAL_DAYS=7

# 是否允许注册
ALLOW_REGISTRATION=true

# ============================================
# 存储配置
# ============================================

# 存储提供者: local / aliyun / cloudflare
STORAGE_PROVIDER=local

# 本地存储路径
STORAGE_LOCAL_PATH=./uploads

# 阿里云OSS配置
# ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
# ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
# ALIYUN_OSS_REGION=oss-cn-hangzhou
# ALIYUN_OSS_BUCKET=your-bucket-name
# ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# ALIYUN_OSS_CDN_DOMAIN=your-cdn-domain.com

# Cloudflare R2配置
# CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
# CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key
# CLOUDFLARE_R2_BUCKET=your-bucket-name
# CLOUDFLARE_R2_PUBLIC_URL=https://your-r2-public-url.com

# ============================================
# AI 功能配置
# ============================================

# 是否启用AI功能
AI_ENABLED=true

# AI API密钥
# AI_API_KEY=your-ai-api-key

# AI模型选择
# AI_MODEL=gpt-4o
# AI_EMBEDDING_MODEL=text-embedding-3-small

# AI每日调用配额（每个租户）
AI_DAILY_QUOTA=100

# ============================================
# 支付配置
# ============================================

# 是否启用支付
PAYMENT_ENABLED=false

# 支付宝配置
# ALIPAY_APP_ID=your-alipay-app-id
# ALIPAY_PRIVATE_KEY=your-alipay-private-key
# ALIPAY_PUBLIC_KEY=your-alipay-public-key
# ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/callback/alipay

# 微信支付配置
# WECHAT_APP_ID=your-wechat-app-id
# WECHAT_MCH_ID=your-wechat-mch-id
# WECHAT_API_KEY=your-wechat-api-key
# WECHAT_NOTIFY_URL=https://your-domain.com/api/payment/callback/wechat

# ============================================
# 邮件配置
# ============================================

# 是否启用邮件
EMAIL_ENABLED=false

# SMTP配置
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-email-password
# SMTP_FROM=your-email@example.com
# SMTP_FROM_NAME=laolin-brain

# ============================================
# 云同步配置
# ============================================

# 是否启用云同步
CLOUD_SYNC_ENABLED=true

# 同步间隔（毫秒）
CLOUD_SYNC_INTERVAL=30000

# ============================================
# 初始化配置
# ============================================

# 首次启动时是否创建默认管理员
INIT_DEFAULT_ADMIN=false

# 默认管理员邮箱
# ADMIN_EMAIL=admin@example.com

# 默认管理员密码
# ADMIN_PASSWORD=your-secure-admin-password

# ============================================
# 日志配置
# ============================================

# 日志级别: debug / info / warn / error / fatal
LOG_LEVEL=info

# 日志保留天数
LOG_RETENTION_DAYS=30

# ============================================
# 监控配置
# ============================================

# 是否启用监控
MONITORING_ENABLED=true

# 健康检查路径
HEALTH_CHECK_PATH=/api/health

# ============================================
# 备份配置
# ============================================

# 是否启用自动备份
BACKUP_ENABLED=true

# 备份保留数量
BACKUP_RETENTION_COUNT=7

# 备份时间（小时，0-23）
BACKUP_SCHEDULE_HOUR=2

# ============================================
# 速率限制
# ============================================

# API速率限制（每分钟请求数）
RATE_LIMIT_PER_MINUTE=100

# 登录速率限制（每IP每分钟）
LOGIN_RATE_LIMIT=5

# ============================================
# 上传配置
# ============================================

# 单个文件最大大小（字节）
MAX_FILE_SIZE=104857600

# 批量上传最大数量
MAX_BATCH_UPLOAD=20

# ============================================
# 会话配置
# ============================================

# 会话过期时间（秒）
SESSION_EXPIRES=86400

# 记住我过期时间（秒）
REMEMBER_ME_EXPIRES=2592000
