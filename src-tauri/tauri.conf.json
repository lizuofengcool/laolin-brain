{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "知识库",
  "version": "1.0.0",
  "identifier": "com.knowledgebase.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "title": "智能文档知识库",
    "windows": [
      {
        "title": "智能文档知识库",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "drag_drop_enabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "capabilities": [
    {
      "identifier": "default",
      "description": "知识库应用的默认权限集",
      "windows": ["main"],
      "permissions": [
        "core:default",
        "fs:default",
        "fs:allow-read",
        "fs:allow-write",
        "fs:allow-exists",
        "fs:allow-mkdir",
        "fs:allow-remove",
        "fs:allow-rename",
        "dialog:default",
        "dialog:allow-open",
        "dialog:allow-save",
        "dialog:allow-message",
        "dialog:allow-ask",
        "notification:default",
        "notification:allow-notify",
        "notification:allow-is-permission-granted",
        "notification:allow-request-permission",
        "shell:default",
        "shell:allow-open",
        "clipboard-manager:default",
        "clipboard-manager:allow-write",
        "clipboard-manager:allow-read"
      ]
    }
  ],
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
